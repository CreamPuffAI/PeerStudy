# GitHub Container Registry namespace (repository owner, lowercase).
GHCR_NAMESPACE=creampuffai

# The tag Watchtower should pull. CI publishes latest on the default branch.
PEERSTUDY_IMAGE_TAG=latest

# Public HTTP port on the VPS.
PEERSTUDY_HTTP_PORT=80

# Watchtower polling interval in seconds.
WATCHTOWER_INTERVAL=300
TZ=Asia/Ho_Chi_Minh

# Run `docker login ghcr.io` first. Override this only if Docker uses another config path.
DOCKER_CONFIG_FILE=/root/.docker/config.json

# FPT AI Market runtime configuration. Keep the real token only in `.env` on
# the VPS; `.env` is gitignored and the token is never baked into an image.
FPT_AI_API_KEY=
FPT_AI_MODEL=
FPT_AI_BASE_URL=https://mkp-api.fptcloud.com/chat/completions
FPT_AI_STREAM=true
FPT_AI_TIMEOUT_SECONDS=8

